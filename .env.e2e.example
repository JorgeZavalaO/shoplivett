# =====================================================================
# Shoplivett — Variables de entorno para Playwright E2E
# Copia este archivo a `.env.e2e` y completa los valores.
# Esta base DEBE ser distinta a la de desarrollo o producción.
# =====================================================================

# Cadena pooled (la que usa el runtime serverless / Next.js).
E2E_DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME_E2E?sslmode=require&pgbouncer=true&connect_timeout=10"
# Cadena directa (la usa `prisma db push` y el seed).
E2E_DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME_E2E?sslmode=require"

# Next.js
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="Shoplivett"
NEXT_PUBLIC_APP_URL="http://localhost:3100"

# Auth.js
AUTH_SECRET=""
AUTH_TRUST_HOST="true"
AUTH_URL="http://localhost:3100"

# Seed de usuarios (E2E)
SEED_ADMIN_EMAIL="admin@shoplivett.local"
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME="Administrador"

SEED_SELLER_EMAIL="seller@shoplivett.local"
SEED_SELLER_PASSWORD=""
SEED_SELLER_NAME="Vendedora"

SEED_DISPATCH_EMAIL="dispatch@shoplivett.local"
SEED_DISPATCH_PASSWORD=""
SEED_DISPATCH_NAME="Despacho"
