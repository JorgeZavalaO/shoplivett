# =====================================================================
# Shoplivett — Variables de entorno
# Copia este archivo a `.env` y completa los valores.
# =====================================================================

# ---------- Base de datos (Neon PostgreSQL) ----------
# Cadena de conexión con connection pooling (recomendado para serverless)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&pgbouncer=true&connect_timeout=10"
# Cadena directa (migraciones / scripts locales)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ---------- Next.js ----------
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="Shoplivett"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------- Auth.js (Sprint 1) ----------
# Generar con: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST="true"
AUTH_URL="http://localhost:3000"

# ---------- Seed de usuarios (Sprint 1) ----------
# Credenciales del administrador inicial. Se crean con pnpm db:seed.
SEED_ADMIN_EMAIL="admin@shoplivett.local"
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME="Administrador"

# Usuarios de ejemplo adicionales para validar el control por rol.
SEED_SELLER_EMAIL="seller@shoplivett.local"
SEED_SELLER_PASSWORD=""
SEED_SELLER_NAME="Vendedora"

SEED_DISPATCH_EMAIL="dispatch@shoplivett.local"
SEED_DISPATCH_PASSWORD=""
SEED_DISPATCH_NAME="Despacho"

# ---------- Vercel Blob (Sprint 4) ----------
BLOB_READ_WRITE_TOKEN=""

# ---------- Notificaciones (Sprint 1) ----------
# Email del remitente para recuperación de contraseña, etc.
EMAIL_FROM="noreply@shoplivett.local"
