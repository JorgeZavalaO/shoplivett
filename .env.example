# =====================================================================
# Shoplivett — Variables de entorno
# Copia este archivo a `.env` y completa los valores.
# En Vercel configura los mismos nombres en Project Settings → Environment Variables.
# =====================================================================

# ---------- Base de datos (Neon PostgreSQL) ----------
# Cadena con pooler (obligatoria para el runtime serverless).
# En Neon: Project → Connection Details → "Pooled connection".
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&pgbouncer=true&connect_timeout=10"
# Cadena directa (migraciones, `prisma migrate`, scripts locales). Sin pgbouncer.
# En Neon: "Direct connection".
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ---------- Next.js ----------
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="Shoplivett"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------- Auth.js (NextAuth v5 / Sprint 1) ----------
# Genera con: openssl rand -base64 32
AUTH_SECRET=""
# Necesario detrás de proxies (Vercel, Neon, etc.).
AUTH_TRUST_HOST="true"
# URL canónica del deploy. En Vercel suele ser https://tu-proyecto.vercel.app
AUTH_URL="http://localhost:3000"

# ---------- Seed de usuarios (Sprint 1) ----------
# Se crean con `pnpm db:seed`. Cambia las contraseñas en producción.
SEED_ADMIN_EMAIL="admin@shoplivett.local"
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME="Administrador"

SEED_SELLER_EMAIL="seller@shoplivett.local"
SEED_SELLER_PASSWORD=""
SEED_SELLER_NAME="Vendedora"

SEED_DISPATCH_EMAIL="dispatch@shoplivett.local"
SEED_DISPATCH_PASSWORD=""
SEED_DISPATCH_NAME="Despacho"

# ---------- Vercel Blob (Sprint 4+) ----------
# Necesario para subir imágenes de producto, variante y capturas de pago.
# Genera el token en Vercel → Storage → Create Database → Blob.
BLOB_READ_WRITE_TOKEN=""

# ---------- Notificaciones (Sprint 1) ----------
EMAIL_FROM="noreply@shoplivett.local"
