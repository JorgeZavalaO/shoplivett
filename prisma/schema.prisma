// Prisma schema - Sprint 23 (incidencias, devoluciones, danos y perdidas)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SELLER
  DISPATCH
}

enum CustomerStatus {
  ACTIVE
  FREQUENT
  RISKY
  BLOCKED
}

enum PaymentMethod {
  YAPE
  PLIN
  CASH
  OTHER
}

enum ShippingMethod {
  DELIVERY_PROPIO
  OLVA
  SHALOM
  MOTORIZADO
  RECOJO
}

enum LiveChannel {
  TIKTOK
  INSTAGRAM
  FACEBOOK
  WHATSAPP
  OTHER
}

enum SalesChannel {
  TIKTOK_LIVE
  INSTAGRAM_LIVE
  TIENDA
  WHATSAPP_DIRECTO
  OTRO
}

enum CostAllocationMethod {
  BY_VALUE
  BY_WEIGHT
  MIXED
  MANUAL
}

enum ImportBatchStatus {
  PURCHASED
  IN_TRANSIT
  COMPLETE
  CLOSED
}

enum LiveStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum VariantStatus {
  ACTIVE
  HIDDEN
  ARCHIVED
}

enum InventoryMovementType {
  IN
  RESERVE
  RELEASE
  SALE
  CANCEL
  ADJUSTMENT
  EXPIRE
}

enum OrderStatus {
  PAYMENT_VALIDATION_PENDING
  RESERVED
  PARTIALLY_PAID
  PAID
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  VALIDATED
  REJECTED
}

enum CreditOrigin {
  OVERPAYMENT
  MANUAL
  REFUND
}

enum CreditStatus {
  AVAILABLE
  PARTIALLY_USED
  USED
  REFUNDED
  VOIDED
}

enum ShipmentStatus {
  PENDING
  PREPARING
  READY
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ExpenseCategory {
  RENT
  PAYROLL
  ADVERTISING
  UTILITIES
  INTERNET
  PACKAGING
  SHIPPING
  OFFICE_SUPPLIES
  PROFESSIONAL_SERVICES
  TAXES
  MAINTENANCE
  OTHER
}

enum ExpenseType {
  FIXED
  VARIABLE
}

enum ExpenseStatus {
  ACTIVE
  VOIDED
}

enum IncidentType {
  RETURN
  DAMAGE
  LOSS
  CLAIM
  EXCHANGE
}

enum IncidentStatus {
  OPEN
  RESOLVED
  CANCELLED
}

enum IncidentReturnDecision {
  RESTOCK
  CREDIT
  REPLACE
  DISCARDED
  NONE
}

enum AuditAction {
  PAYMENT_VALIDATED
  PAYMENT_REJECTED
  PAYMENT_APPLICATIONS_UPDATED
  ORDER_CREATED
  ORDER_CANCELLED
  ORDER_EXPIRED
  ORDER_STATUS_CHANGED
  INVENTORY_ADJUSTED
  RESERVATION_EXPIRED
  SHIPMENT_CREATED
  SHIPMENT_STATUS_CHANGED
  SHIPMENT_CANCELLED
  PRODUCT_PRICE_CHANGED
  CUSTOMER_DEACTIVATED
  CUSTOMER_STATUS_CHANGED
  CREDIT_CREATED
  CREDIT_REFUNDED
  CREDIT_APPLIED
  SETTINGS_UPDATED
  IMPORT_BATCH_CREATED
  IMPORT_BATCH_UPDATED
  IMPORT_BATCH_STATUS_CHANGED
  IMPORT_BATCH_ITEM_ADDED
  IMPORT_BATCH_ITEM_REMOVED
  IMPORT_BATCH_RECALCULATED
  ORDER_BATCH_ALLOCATED
  ORDER_BATCH_ALLOCATION_RELEASED
  ORDER_PROFIT_RECOGNIZED
  EXPENSE_CREATED
  EXPENSE_UPDATED
  EXPENSE_VOIDED
  INCIDENT_CREATED
  INCIDENT_RESOLVED
  INCIDENT_CANCELLED
}

enum OrderItemCostSource {
  BATCH
  LEGACY
  NONE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(SELLER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sessions     Session[]
  lives        LiveSession[]
  validatedPayments Payment[] @relation("PaymentValidator")
  rejectedPayments  Payment[] @relation("PaymentRejector")
  createdCredits  CustomerCredit[]   @relation("CreditCreator")
  refundedCredits  CustomerCredit[]   @relation("CreditRefunder")
  createdCreditApplications CustomerCreditApplication[] @relation("CreditApplicationCreator")
  cancelledReservations   Order[]            @relation("OrderExpirer")
  createdShipments        Shipment[]         @relation("ShipmentCreator")
  updatedShipments        Shipment[]         @relation("ShipmentUpdater")
  auditLogs               AuditLog[]         @relation("AuditActor")
  createdImportBatches    ImportBatch[]      @relation("ImportBatchCreator")
  createdExpenses        Expense[]          @relation("ExpenseCreator")
  voidedExpenses         Expense[]          @relation("ExpenseVoider")
  createdIncidents       Incident[]         @relation("IncidentCreator")
  resolvedIncidents      Incident[]         @relation("IncidentResolver")

  @@index([email])
  @@index([role])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BusinessSettings {
  id                            String   @id @default("default")
  reservationDays               Int      @default(5)
  minimumAdvance                Decimal  @default(50) @db.Decimal(12, 2)
  currency                      String   @default("PEN") @db.VarChar(3)
  freeShippingEnabled           Boolean  @default(true)
  freeShippingThreshold         Decimal  @default(150) @db.Decimal(12, 2)
  productCodePrefix             String   @default("CART") @db.VarChar(6)
  allowOverpaymentCredit        Boolean  @default(true)
  allowRefund                   Boolean  @default(true)
  enabledPaymentMethods         PaymentMethod[]    @default([YAPE, PLIN])
  enabledShippingMethods        ShippingMethod[]   @default([DELIVERY_PROPIO, OLVA, SHALOM, MOTORIZADO, RECOJO])
  paymentValidatorRoles         Role[]             @default([ADMIN, SELLER])
  defaultExchangeRate           Decimal  @default(3.75) @db.Decimal(10, 4)
  minimumTargetMarginBps        Int      @default(1500)
  objectiveTargetMarginBps      Int      @default(3000)
  defaultCostAllocationMethod   CostAllocationMethod @default(MIXED)
  mixedValueAllocationPercent   Int      @default(50)
  mixedWeightAllocationPercent  Int      @default(50)
  standardPackagingCostPen      Decimal  @default(2) @db.Decimal(12, 2)
  paymentMethodFees             Json     @default("{\"YAPE\":0,\"PLIN\":0,\"CASH\":0,\"OTHER\":0}")
  enabledSalesChannels          SalesChannel[] @default([TIKTOK_LIVE, INSTAGRAM_LIVE, TIENDA, WHATSAPP_DIRECTO])
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
}

model Customer {
  id         String         @id @default(cuid())
  name       String
  searchName String
  whatsapp   String         @unique
  document   String?
  address    String?
  district   String?
  reference  String?
  channel    String?
  notes      String?
  status     CustomerStatus @default(ACTIVE)
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  orders     Order[]
  payments   Payment[]
  credits    CustomerCredit[]
  shipments  Shipment[]
  incidents  Incident[]

  @@index([searchName])
  @@index([whatsapp])
  @@index([status])
  @@index([isActive])
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@index([isActive])
}

model Product {
  id          String           @id @default(cuid())
  name        String
  description String?
  categoryId  String
  category    Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  variants    ProductVariant[]
  images      ProductImage[]

  @@index([categoryId])
  @@index([isActive])
  @@index([name])
  @@index([categoryId, isActive, createdAt])
}

model ProductVariant {
  id            String              @id @default(cuid())
  productId     String
  product       Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  code          String              @unique
  color         String?
  material      String?
  size          String?
  price         Decimal             @db.Decimal(12, 2)
  cost          Decimal?            @db.Decimal(12, 2)
  stock         Int                 @default(0)
  reservedStock Int                 @default(0)
  soldStock     Int                 @default(0)
  status        VariantStatus       @default(ACTIVE)
  barcode       String?             @unique
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  images        ProductImage[]
  movements     InventoryMovement[]
  orderItems    OrderItem[]
  batchItems    ImportBatchItem[]
  incidents     Incident[]

  @@index([productId])
  @@index([status])
  @@index([color])
}

model ProductImage {
  id        String           @id @default(cuid())
  url       String
  pathname  String
  productId String?
  product   Product?         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  variant   ProductVariant?  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  isPrimary Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([productId])
  @@index([variantId])
}

model InventoryMovement {
  id        String                @id @default(cuid())
  variantId String
  variant   ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  type      InventoryMovementType
  quantity  Int
  reason    String?
  createdAt DateTime              @default(now())

  @@index([variantId])
  @@index([type])
}

model LiveSession {
  id            String      @id @default(cuid())
  name          String
  channel       LiveChannel @default(TIKTOK)
  responsibleId String?
  responsible   User?       @relation(fields: [responsibleId], references: [id], onDelete: SetNull)
  status        LiveStatus  @default(OPEN)
  startedAt     DateTime    @default(now())
  closedAt      DateTime?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orders        Order[]

  @@index([status])
  @@index([startedAt])
  @@index([responsibleId])
  @@index([status, startedAt])
}

model Order {
  id             String       @id @default(cuid())
  orderNumber    String       @unique
  customerId     String
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  liveSessionId  String?
  liveSession    LiveSession? @relation(fields: [liveSessionId], references: [id], onDelete: SetNull)
  status         OrderStatus  @default(PAYMENT_VALIDATION_PENDING)
  subtotal       Decimal      @db.Decimal(12, 2)
  discount       Decimal      @db.Decimal(12, 2) @default(0)
  shippingAmount Decimal      @db.Decimal(12, 2) @default(0)
  total          Decimal      @db.Decimal(12, 2)
  validatedPaid  Decimal      @db.Decimal(12, 2) @default(0)
  balance        Decimal      @db.Decimal(12, 2)
  expiresAt      DateTime
  notes          String?
  // Sprint 21
  salesChannel    SalesChannel  @default(WHATSAPP_DIRECTO)
  productCostPen  Decimal       @default(0) @db.Decimal(12, 2)
  grossProfitPen  Decimal       @default(0) @db.Decimal(12, 2)
  paymentFeePen   Decimal       @default(0) @db.Decimal(12, 2)
  packagingCostPen Decimal      @default(0) @db.Decimal(12, 2)
  netProfitPen    Decimal       @default(0) @db.Decimal(12, 2)
  profitCalculatedAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  items     OrderItem[]
  payments  Payment[]
  paymentApplications PaymentApplication[]
  creditApplications  CustomerCreditApplication[]
  shipmentOrder        ShipmentOrder?
  expiredById  String?
  expiredBy    User?      @relation("OrderExpirer", fields: [expiredById], references: [id], onDelete: SetNull)
  expiredAt    DateTime?
  incidents    Incident[]

  @@index([customerId])
  @@index([liveSessionId])
  @@index([status])
  @@index([expiresAt])
  @@index([status, createdAt])
  @@index([status, expiresAt])
  @@index([customerId, status, createdAt])
  @@index([status, expiresAt, customerId])
  @@index([salesChannel])
}

model OrderItem {
  id        String         @id @default(cuid())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  quantity  Int
  unitPrice Decimal        @db.Decimal(12, 2)
  lineTotal Decimal        @db.Decimal(12, 2)
  // Sprint 21 — snapshots financieros
  costSource       OrderItemCostSource @default(NONE)
  unitCostPen      Decimal             @default(0) @db.Decimal(12, 4)
  totalCostPen     Decimal             @default(0) @db.Decimal(12, 2)
  netLineRevenuePen Decimal            @default(0) @db.Decimal(12, 2)
  lineDiscountPen  Decimal             @default(0) @db.Decimal(12, 2)
  grossProfitPen   Decimal             @default(0) @db.Decimal(12, 2)
  createdAt DateTime       @default(now())
  allocations      OrderItemBatchAllocation[]
  incidents        Incident[]

  @@index([orderId])
  @@index([variantId])
}

model OrderItemBatchAllocation {
  id          String         @id @default(cuid())
  orderItemId String
  orderItem   OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  batchItemId String
  batchItem   ImportBatchItem @relation(fields: [batchItemId], references: [id], onDelete: Restrict)
  batchId     String
  variantId   String
  quantity    Int
  unitCostPen Decimal        @db.Decimal(12, 4)
  subtotalCostPen Decimal    @db.Decimal(12, 2)
  createdAt   DateTime       @default(now())

  @@index([orderItemId])
  @@index([batchItemId])
  @@index([batchId])
  @@index([variantId])
}

model Payment {
  id              String        @id @default(cuid())
  customerId      String
  customer        Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  orderId         String?
  order           Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(12, 2)
  operationNumber String?
  notes           String?
  validatedAt     DateTime?
  validatedById   String?
  validatedBy     User?         @relation("PaymentValidator", fields: [validatedById], references: [id], onDelete: SetNull)
  rejectedAt      DateTime?
  rejectedById    String?
  rejectedBy      User?         @relation("PaymentRejector", fields: [rejectedById], references: [id], onDelete: SetNull)
  rejectionReason String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  receipts    PaymentReceipt[]
  applications PaymentApplication[]
  credits        CustomerCredit[]

  @@index([customerId])
  @@index([orderId])
  @@index([status])
  @@index([validatedById])
  @@index([rejectedById])
  @@index([status, createdAt])
  @@index([customerId, status, createdAt])
}

model PaymentReceipt {
  id        String   @id @default(cuid())
  paymentId String
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  url       String
  pathname  String
  createdAt DateTime @default(now())

  @@index([paymentId])
}

model PaymentApplication {
  id        String   @id @default(cuid())
  paymentId String
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  @@unique([paymentId, orderId])
  @@index([paymentId])
  @@index([orderId])
}

model CustomerCredit {
  id              String       @id @default(cuid())
  customerId      String
  customer        Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  paymentId       String?
  payment         Payment?     @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  origin          CreditOrigin
  status          CreditStatus @default(AVAILABLE)
  amount          Decimal      @db.Decimal(12, 2)
  availableAmount Decimal      @db.Decimal(12, 2)
  notes           String?
  createdById     String?
  createdBy       User?        @relation("CreditCreator", fields: [createdById], references: [id], onDelete: SetNull)
  refundedAt      DateTime?
  refundedById    String?
  refundedBy      User?        @relation("CreditRefunder", fields: [refundedById], references: [id], onDelete: SetNull)
  refundReason    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  applications CustomerCreditApplication[]
  incidents    Incident[]

  @@index([customerId])
  @@index([paymentId])
  @@index([status])
  @@index([origin])
  @@index([customerId, status, createdAt])
}

model CustomerCreditApplication {
  id        String        @id @default(cuid())
  creditId  String
  credit    CustomerCredit @relation(fields: [creditId], references: [id], onDelete: Cascade)
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount    Decimal        @db.Decimal(12, 2)
  createdById String?
  createdBy   User?        @relation("CreditApplicationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt DateTime       @default(now())

  @@index([creditId])
  @@index([orderId])
}

model Shipment {
  id                 String          @id @default(cuid())
  customerId         String
  customer           Customer        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  shippingMethod     ShippingMethod
  status             ShipmentStatus  @default(PENDING)
  shippingCost       Decimal         @db.Decimal(12, 2) @default(0)
  isFreeShipping     Boolean         @default(false)
  freeShippingRule   Json?
  agencyName         String?
  trackingCode       String?
  addressSnapshot    String?
  districtSnapshot   String?
  referenceSnapshot  String?
  notes              String?
  preparedAt         DateTime?
  shippedAt          DateTime?
  deliveredAt        DateTime?
  cancelledAt        DateTime?
  createdById        String?
  createdBy          User?           @relation("ShipmentCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById        String?
  updatedBy          User?           @relation("ShipmentUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  orders ShipmentOrder[]

  @@index([customerId])
  @@index([status])
  @@index([shippingMethod])
  @@index([createdAt])
  @@index([status, updatedAt])
  @@index([customerId, status, createdAt])
}

model ShipmentOrder {
  id         String   @id @default(cuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([shipmentId])
  @@index([orderId])
}

model ImportBatch {
  id                    String             @id @default(cuid())
  code                  String             @unique
  purchaseDate          DateTime
  shopper               String
  agency                String
  totalCostUsd          Decimal            @db.Decimal(12, 2)
  totalAdditionalCostsUsd Decimal           @db.Decimal(12, 2) @default(0)
  totalAdditionalCostsPen Decimal           @db.Decimal(12, 2) @default(0)
  exchangeRate          Decimal            @db.Decimal(10, 4)
  totalInvestmentPen    Decimal            @db.Decimal(12, 2)
  status                ImportBatchStatus  @default(PURCHASED)
  distributionMethod    CostAllocationMethod @default(MIXED)
  distributionBreakdown  Json?
  lastRecalculatedAt    DateTime?
  notes                 String?
  createdById           String?
  createdBy             User?              @relation("ImportBatchCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  items ImportBatchItem[]

  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}

model ImportBatchItem {
  id               String         @id @default(cuid())
  batchId          String
  batch            ImportBatch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  variantId        String
  variant          ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  quantityPurchased Int           @default(0)
  quantityReceived  Int           @default(0)
  quantityAvailable Int           @default(0)
  unitCostUsd      Decimal        @db.Decimal(12, 4)
  unitCostPen      Decimal        @db.Decimal(12, 4)
  weight           Decimal        @db.Decimal(10, 4) @default(0)
  subtotalUsd      Decimal        @db.Decimal(12, 2)
  subtotalPen      Decimal        @db.Decimal(12, 2)
  // Costos aterrizados (Sprint 20)
  additionalCostPen       Decimal     @default(0) @db.Decimal(12, 4)
  additionalSubtotalPen   Decimal     @default(0) @db.Decimal(12, 2)
  landedUnitCostPen       Decimal     @default(0) @db.Decimal(12, 4)
  landedSubtotalPen       Decimal     @default(0) @db.Decimal(12, 2)
  distributionBreakdown   Json?
  calculatedAt             DateTime?
  createdAt        DateTime       @default(now())
  allocations      OrderItemBatchAllocation[]

  @@unique([batchId, variantId])
  @@index([batchId])
  @@index([variantId])
  @@index([variantId, quantityAvailable])
  @@index([batchId, calculatedAt])
}

model Expense {
  id            String         @id @default(cuid())
  expenseDate   DateTime
  category      ExpenseCategory
  expenseType   ExpenseType    @default(VARIABLE)
  status        ExpenseStatus  @default(ACTIVE)
  description   String
  amount        Decimal        @db.Decimal(12, 2)
  paymentMethod String?
  notes         String?
  createdById   String?
  createdBy     User?          @relation("ExpenseCreator", fields: [createdById], references: [id], onDelete: SetNull)
  voidedAt      DateTime?
  voidedById    String?
  voidedBy      User?          @relation("ExpenseVoider", fields: [voidedById], references: [id], onDelete: SetNull)
  voidReason    String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([expenseDate])
  @@index([category])
  @@index([status])
  @@index([expenseType])
  @@index([status, expenseDate])
  @@index([expenseDate, category])
}

model Incident {
  id              String                  @id @default(cuid())
  incidentDate    DateTime
  type            IncidentType
  status          IncidentStatus          @default(OPEN)
  decision        IncidentReturnDecision  @default(NONE)
  orderId         String?
  order           Order?                  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderItemId     String?
  orderItem       OrderItem?              @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  variantId       String?
  variant         ProductVariant?         @relation(fields: [variantId], references: [id], onDelete: SetNull)
  customerId      String?
  customer        Customer?               @relation(fields: [customerId], references: [id], onDelete: SetNull)
  quantity        Int                     @default(1)
  description     String
  recoveredAmount Decimal                 @default(0) @db.Decimal(12, 2)
  lostAmount      Decimal                 @default(0) @db.Decimal(12, 2)
  restockQuantity Int                     @default(0)
  creditId        String?
  credit          CustomerCredit?         @relation(fields: [creditId], references: [id], onDelete: SetNull)
  notes           String?
  createdById     String?
  createdBy       User?                   @relation("IncidentCreator", fields: [createdById], references: [id], onDelete: SetNull)
  resolvedAt      DateTime?
  resolvedById    String?
  resolvedBy      User?                   @relation("IncidentResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolutionNotes String?
  cancelledAt     DateTime?
  cancelledById   String?
  cancelledReason String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([incidentDate])
  @@index([type])
  @@index([status])
  @@index([orderId])
  @@index([orderItemId])
  @@index([variantId])
  @@index([customerId])
  @@index([status, incidentDate])
  @@index([type, incidentDate])
}

model LoginRateLimit {
  id             String    @id @default(cuid())
  key            String    @unique
  failedAttempts Int       @default(0)
  windowStart    DateTime
  blockedUntil   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([blockedUntil])
  @@index([updatedAt])
}

model AuditLog {
  id        String      @id @default(cuid())
  action    AuditAction
  entity    String
  entityId  String
  actorId   String?
  actor     User?       @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([action, createdAt])
  @@index([entity, entityId])
  @@index([actorId, createdAt])
  @@index([createdAt])
}
