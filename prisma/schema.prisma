// Prisma schema - Sprint 3 (clientes)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SELLER
  DISPATCH
}

enum CustomerStatus {
  ACTIVE
  FREQUENT
  RISKY
  BLOCKED
}

enum PaymentMethod {
  YAPE
  PLIN
  CASH
  OTHER
}

enum ShippingMethod {
  DELIVERY_PROPIO
  OLVA
  SHALOM
  MOTORIZADO
  RECOJO
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(SELLER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sessions     Session[]

  @@index([email])
  @@index([role])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BusinessSettings {
  id                     String   @id @default("default")
  reservationDays        Int      @default(5)
  minimumAdvance         Decimal  @default(50) @db.Decimal(12, 2)
  currency               String   @default("PEN") @db.VarChar(3)
  freeShippingEnabled    Boolean  @default(true)
  freeShippingThreshold  Decimal  @default(150) @db.Decimal(12, 2)
  productCodePrefix      String   @default("CART") @db.VarChar(6)
  allowOverpaymentCredit Boolean  @default(true)
  allowRefund            Boolean  @default(true)
  enabledPaymentMethods  PaymentMethod[]    @default([YAPE, PLIN])
  enabledShippingMethods ShippingMethod[]   @default([DELIVERY_PROPIO, OLVA, SHALOM, MOTORIZADO, RECOJO])
  paymentValidatorRoles  Role[]             @default([ADMIN, SELLER])
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Customer {
  id         String         @id @default(cuid())
  name       String
  searchName String
  whatsapp   String         @unique
  document   String?
  address    String?
  district   String?
  reference  String?
  channel    String?
  notes      String?
  status     CustomerStatus @default(ACTIVE)
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([searchName])
  @@index([whatsapp])
  @@index([status])
  @@index([isActive])
}
