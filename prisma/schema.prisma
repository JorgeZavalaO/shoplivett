// Prisma schema - Sprint 10 (envíos agrupados)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SELLER
  DISPATCH
}

enum CustomerStatus {
  ACTIVE
  FREQUENT
  RISKY
  BLOCKED
}

enum PaymentMethod {
  YAPE
  PLIN
  CASH
  OTHER
}

enum ShippingMethod {
  DELIVERY_PROPIO
  OLVA
  SHALOM
  MOTORIZADO
  RECOJO
}

enum LiveChannel {
  TIKTOK
  INSTAGRAM
  FACEBOOK
  WHATSAPP
  OTHER
}

enum LiveStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum VariantStatus {
  ACTIVE
  HIDDEN
  ARCHIVED
}

enum InventoryMovementType {
  IN
  RESERVE
  RELEASE
  SALE
  CANCEL
  ADJUSTMENT
  EXPIRE
}

enum OrderStatus {
  PAYMENT_VALIDATION_PENDING
  RESERVED
  PARTIALLY_PAID
  PAID
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  VALIDATED
  REJECTED
}

enum CreditOrigin {
  OVERPAYMENT
  MANUAL
  REFUND
}

enum CreditStatus {
  AVAILABLE
  PARTIALLY_USED
  USED
  REFUNDED
  VOIDED
}

enum ShipmentStatus {
  PENDING
  PREPARING
  READY
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(SELLER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sessions     Session[]
  lives        LiveSession[]
  validatedPayments Payment[] @relation("PaymentValidator")
  rejectedPayments  Payment[] @relation("PaymentRejector")
  createdCredits  CustomerCredit[]   @relation("CreditCreator")
  refundedCredits  CustomerCredit[]   @relation("CreditRefunder")
  createdCreditApplications CustomerCreditApplication[] @relation("CreditApplicationCreator")
  cancelledReservations   Order[]            @relation("OrderExpirer")
  createdShipments        Shipment[]         @relation("ShipmentCreator")
  updatedShipments        Shipment[]         @relation("ShipmentUpdater")

  @@index([email])
  @@index([role])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BusinessSettings {
  id                     String   @id @default("default")
  reservationDays        Int      @default(5)
  minimumAdvance         Decimal  @default(50) @db.Decimal(12, 2)
  currency               String   @default("PEN") @db.VarChar(3)
  freeShippingEnabled    Boolean  @default(true)
  freeShippingThreshold  Decimal  @default(150) @db.Decimal(12, 2)
  productCodePrefix      String   @default("CART") @db.VarChar(6)
  allowOverpaymentCredit Boolean  @default(true)
  allowRefund            Boolean  @default(true)
  enabledPaymentMethods  PaymentMethod[]    @default([YAPE, PLIN])
  enabledShippingMethods ShippingMethod[]   @default([DELIVERY_PROPIO, OLVA, SHALOM, MOTORIZADO, RECOJO])
  paymentValidatorRoles  Role[]             @default([ADMIN, SELLER])
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Customer {
  id         String         @id @default(cuid())
  name       String
  searchName String
  whatsapp   String         @unique
  document   String?
  address    String?
  district   String?
  reference  String?
  channel    String?
  notes      String?
  status     CustomerStatus @default(ACTIVE)
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  orders     Order[]
  payments   Payment[]
  credits    CustomerCredit[]
  shipments  Shipment[]

  @@index([searchName])
  @@index([whatsapp])
  @@index([status])
  @@index([isActive])
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@index([isActive])
}

model Product {
  id          String           @id @default(cuid())
  name        String
  description String?
  categoryId  String
  category    Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  variants    ProductVariant[]
  images      ProductImage[]

  @@index([categoryId])
  @@index([isActive])
  @@index([name])
}

model ProductVariant {
  id            String              @id @default(cuid())
  productId     String
  product       Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  code          String              @unique
  color         String?
  material      String?
  size          String?
  price         Decimal             @db.Decimal(12, 2)
  cost          Decimal?            @db.Decimal(12, 2)
  stock         Int                 @default(0)
  reservedStock Int                 @default(0)
  soldStock     Int                 @default(0)
  status        VariantStatus       @default(ACTIVE)
  barcode       String?             @unique
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  images        ProductImage[]
  movements     InventoryMovement[]
  orderItems    OrderItem[]

  @@index([productId])
  @@index([status])
  @@index([color])
}

model ProductImage {
  id        String           @id @default(cuid())
  url       String
  pathname  String
  productId String?
  product   Product?         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  variant   ProductVariant?  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  isPrimary Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([productId])
  @@index([variantId])
}

model InventoryMovement {
  id        String                @id @default(cuid())
  variantId String
  variant   ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  type      InventoryMovementType
  quantity  Int
  reason    String?
  createdAt DateTime              @default(now())

  @@index([variantId])
  @@index([type])
}

model LiveSession {
  id            String      @id @default(cuid())
  name          String
  channel       LiveChannel @default(TIKTOK)
  responsibleId String?
  responsible   User?       @relation(fields: [responsibleId], references: [id], onDelete: SetNull)
  status        LiveStatus  @default(OPEN)
  startedAt     DateTime    @default(now())
  closedAt      DateTime?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  orders        Order[]

  @@index([status])
  @@index([startedAt])
  @@index([responsibleId])
}

model Order {
  id             String       @id @default(cuid())
  orderNumber    String       @unique
  customerId     String
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  liveSessionId  String?
  liveSession    LiveSession? @relation(fields: [liveSessionId], references: [id], onDelete: SetNull)
  status         OrderStatus  @default(PAYMENT_VALIDATION_PENDING)
  subtotal       Decimal      @db.Decimal(12, 2)
  discount       Decimal      @db.Decimal(12, 2) @default(0)
  shippingAmount Decimal      @db.Decimal(12, 2) @default(0)
  total          Decimal      @db.Decimal(12, 2)
  validatedPaid  Decimal      @db.Decimal(12, 2) @default(0)
  balance        Decimal      @db.Decimal(12, 2)
  expiresAt      DateTime
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  items     OrderItem[]
  payments  Payment[]
  paymentApplications PaymentApplication[]
  creditApplications  CustomerCreditApplication[]
  shipmentOrder        ShipmentOrder?
  expiredById  String?
  expiredBy    User?      @relation("OrderExpirer", fields: [expiredById], references: [id], onDelete: SetNull)
  expiredAt    DateTime?

  @@index([customerId])
  @@index([liveSessionId])
  @@index([status])
  @@index([expiresAt])
}

model OrderItem {
  id        String         @id @default(cuid())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  quantity  Int
  unitPrice Decimal        @db.Decimal(12, 2)
  lineTotal Decimal        @db.Decimal(12, 2)
  createdAt DateTime       @default(now())

  @@index([orderId])
  @@index([variantId])
}

model Payment {
  id              String        @id @default(cuid())
  customerId      String
  customer        Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  orderId         String?
  order           Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(12, 2)
  operationNumber String?
  notes           String?
  validatedAt     DateTime?
  validatedById   String?
  validatedBy     User?         @relation("PaymentValidator", fields: [validatedById], references: [id], onDelete: SetNull)
  rejectedAt      DateTime?
  rejectedById    String?
  rejectedBy      User?         @relation("PaymentRejector", fields: [rejectedById], references: [id], onDelete: SetNull)
  rejectionReason String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  receipts    PaymentReceipt[]
  applications PaymentApplication[]
  credits        CustomerCredit[]

  @@index([customerId])
  @@index([orderId])
  @@index([status])
  @@index([validatedById])
  @@index([rejectedById])
}

model PaymentReceipt {
  id        String   @id @default(cuid())
  paymentId String
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  url       String
  pathname  String
  createdAt DateTime @default(now())

  @@index([paymentId])
}

model PaymentApplication {
  id        String   @id @default(cuid())
  paymentId String
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  @@unique([paymentId, orderId])
  @@index([paymentId])
  @@index([orderId])
}

model CustomerCredit {
  id              String       @id @default(cuid())
  customerId      String
  customer        Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  paymentId       String?
  payment         Payment?     @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  origin          CreditOrigin
  status          CreditStatus @default(AVAILABLE)
  amount          Decimal      @db.Decimal(12, 2)
  availableAmount Decimal      @db.Decimal(12, 2)
  notes           String?
  createdById     String?
  createdBy       User?        @relation("CreditCreator", fields: [createdById], references: [id], onDelete: SetNull)
  refundedAt      DateTime?
  refundedById    String?
  refundedBy      User?        @relation("CreditRefunder", fields: [refundedById], references: [id], onDelete: SetNull)
  refundReason    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  applications CustomerCreditApplication[]

  @@index([customerId])
  @@index([paymentId])
  @@index([status])
  @@index([origin])
}

model CustomerCreditApplication {
  id        String        @id @default(cuid())
  creditId  String
  credit    CustomerCredit @relation(fields: [creditId], references: [id], onDelete: Cascade)
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount    Decimal        @db.Decimal(12, 2)
  createdById String?
  createdBy   User?        @relation("CreditApplicationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt DateTime       @default(now())

  @@index([creditId])
  @@index([orderId])
}

model Shipment {
  id                 String          @id @default(cuid())
  customerId         String
  customer           Customer        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  shippingMethod     ShippingMethod
  status             ShipmentStatus  @default(PENDING)
  shippingCost       Decimal         @db.Decimal(12, 2) @default(0)
  isFreeShipping     Boolean         @default(false)
  freeShippingRule   Json?
  agencyName         String?
  trackingCode       String?
  addressSnapshot    String?
  districtSnapshot   String?
  referenceSnapshot  String?
  notes              String?
  preparedAt         DateTime?
  shippedAt          DateTime?
  deliveredAt        DateTime?
  cancelledAt        DateTime?
  createdById        String?
  createdBy          User?           @relation("ShipmentCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById        String?
  updatedBy          User?           @relation("ShipmentUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  orders ShipmentOrder[]

  @@index([customerId])
  @@index([status])
  @@index([shippingMethod])
  @@index([createdAt])
}

model ShipmentOrder {
  id         String   @id @default(cuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([shipmentId])
  @@index([orderId])
}
